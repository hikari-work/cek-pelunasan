# ============================================================
# MONGODB (wajib)
# Nama env "SPRING_DATA_MONGODB_URI" dipertahankan dari versi Java
# untuk kompatibilitas .env existing.
# ============================================================
SPRING_DATA_MONGODB_URI=mongodb+srv://username:password@host/dbname?appName=Bot

# ============================================================
# TELEGRAM BOT (wajib)
# ============================================================
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_BOT_OWNER=your_telegram_chat_id

# ============================================================
# CLOUDFLARE R2 (opsional — kalau kosong, fitur SLIK dinonaktifkan)
# ============================================================
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY=your_access_key
R2_SECRET_KEY=your_secret_key
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
R2_BUCKET=your_bucket_name

# ============================================================
# WHATSAPP (whatsmeow native — tidak butuh gateway terpisah)
#
# WA_DB_PATH    : file SQLite untuk session whatsmeow.
# WA_DEVICE_NAME: muncul di "Linked devices" di HP user.
# WA_LOG_LEVEL  : DEBUG/INFO/WARN/ERROR untuk log internal whatsmeow.
# ADMIN_WHATSAPP: nomor admin (tanpa @s.whatsapp.net), dipakai untuk
#                 gating handler admin (.jb, .minbunga, .email, shortcut).
# WA_COMMAND_PREFIX: awalan command bisnis (.p, .t, .va, dll).
#                    Boleh diganti ke "!", "#", "/", dst.
# WA_ALLOW_SELF_MESSAGES: kalau true, pesan dari device bot sendiri tetap
#                         diproses (untuk dev/testing single-account).
#                         Default false untuk hindari loop.
# ============================================================
WA_DB_PATH=./data/wa.db
WA_DEVICE_NAME=cek-pelunasan
WA_LOG_LEVEL=INFO
ADMIN_WHATSAPP=628123456789
WA_COMMAND_PREFIX=.
WA_ALLOW_SELF_MESSAGES=false

# ============================================================
# EMAIL FORWARD (opsional — handler .email/.done)
# Kalau MAIL_HOST atau EMAIL_FORWARD_FROM kosong, fitur dinonaktifkan.
# Port 465 = implicit TLS; 587 = STARTTLS.
# ============================================================
MAIL_HOST=smtp.sumopod.com
MAIL_PORT=465
MAIL_USERNAME=your_smtp_username
MAIL_PASSWORD=your_smtp_password
EMAIL_FORWARD_FROM=bot@yourdomain.com
EMAIL_FORWARD_RECIPIENT=ops@yourdomain.com

# ============================================================
# SLIK PDF GENERATOR (butuh wkhtmltopdf di PATH)
# ============================================================
PDF_ENDPOINT_URL=https://kredit.suryayudha.id/ideb/generate.php
PDF_LOGO_URL=https://kredit.suryayudha.id/ideb/logo.png
SLIK_PDF_MAX_SIZE=5242880000
SLIK_SEARCH_TIMEOUT_SECONDS=30
SLIK_MAX_RESULTS=50

# ============================================================
# MINI APP (Telegram WebApp)
# Kalau MINIAPP_URL kosong, command /app dinonaktifkan.
# ============================================================
MINIAPP_URL=https://your-domain.com
MINIAPP_SESSION_TTL_MINUTES=60

# ============================================================
# SERVER (Fiber: Mini App API + actuator)
# ============================================================
SERVER_PORT=8080
