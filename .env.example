# ============================================================
# MONGODB
# ============================================================
SPRING_DATA_MONGODB_URI=mongodb+srv://username:password@host/dbname?appName=Bot

# ============================================================
# TELEGRAM BOT
# ============================================================
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_BOT_OWNER=your_telegram_chat_id

# ============================================================
# TDLIGHT
# Dapatkan dari https://my.telegram.org
# ============================================================
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=your_api_hash

# ============================================================
# CLOUDFLARE R2
# ============================================================
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY=your_access_key
R2_SECRET_KEY=your_secret_key
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
R2_BUCKET=your_bucket_name

# ============================================================
# WHATSAPP GATEWAY
# URL tidak perlu diisi saat pakai Docker — sudah di-override ke http://whatsapp-gateway:3000
# Saat jalan tanpa Docker, isi dengan URL WhatsApp gateway yang berjalan
# ============================================================
WHATSAPP_GATEWAY_URL=http://localhost:3000
WHATSAPP_GATEWAY_USERNAME=admin
WHATSAPP_GATEWAY_PASSWORD=admin_password
WHATSAPP_DEVICE_ID=your_device_id
ADMIN_WHATSAPP=628123456789

# ============================================================
# SERVER
# ============================================================
SERVER_PORT=8080
