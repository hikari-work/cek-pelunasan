# ============================================================
# DATABASE (Spring Boot relaxed binding: spring.datasource.*)
# ============================================================
SPRING_DATASOURCE_URL=jdbc:mysql://your-db-host:3306/cek_pelunasan?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Jakarta
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your_password
SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=10

# ============================================================
# TELEGRAM BOT (telegram.bot.*)
# ============================================================
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_BOT_OWNER=your_telegram_chat_id

# ============================================================
# TDLIGHT (telegram.api.*)
# Dapatkan dari https://my.telegram.org
# ============================================================
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=your_api_hash

# ============================================================
# CLOUDFLARE R2 (r2.*)
# ============================================================
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY=your_access_key
R2_SECRET_KEY=your_secret_key
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
R2_BUCKET=your_bucket_name

# ============================================================
# WHATSAPP GATEWAY
# URL tidak perlu diisi — sudah di-override docker-compose ke http://whatsapp-gateway:3000
# ============================================================
WHATSAPP_GATEWAY_USERNAME=admin
WHATSAPP_GATEWAY_PASSWORD=admin_password
ADMIN_WHATSAPP=628123456789

# ============================================================
# SERVER
# ============================================================
SERVER_PORT=8080
